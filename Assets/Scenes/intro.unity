  _cards:
  - Image: {fileID: 2680967238807739287, guid: cb40922938465a349ba94901f422f1ce, type: 3}
    NarrationText: "Sonsuz ye\u015Filliklerin i\xE7inde, do\u011Fan\u0131n kalbinde
      gizemli bir robot olarak uyand\u0131m..."
  - Image: {fileID: -8338419070329957434, guid: a06053290b366844db55d21bf63a1a8a, type: 3}
    NarrationText: "Fakat ormanda ters giden bir \u015Feyler vard\u0131. Canl\u0131lar
      sald\u0131rganla\u015Fm\u0131\u015F, as\u0131rl\u0131k a\u011Fa\xE7lar birer
      birer yok oluyordu..."
  - Image: {fileID: -8907945267164518999, guid: beaa7774f874b4046829b1719b9dd5e8, type: 3}
    NarrationText: "Do\u011Fan\u0131n bu \xE7\u0131\u011Fl\u0131\u011F\u0131n\u0131
      dindirmek ve orman\u0131 eski huzuruna kavu\u015Fturmak art\u0131k benim g\xF6revimdi.
      Yolculuk ba\u015Flas\u0131n!"
  _typewriterSpeed: 0.035
  _cardFadeDuration: 0.4
  _nextSceneName: Level_01
